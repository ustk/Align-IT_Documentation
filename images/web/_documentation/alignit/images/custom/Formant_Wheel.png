.elementor-50 .elementor-element.elementor-element-7d8c0bb.elementor-sticky--effects{
background: #fff!important;
}

/*Sticky Header Links and Icons*/
.elementor-50 .elementor-element.elementor-element-7d8c0bb.elementor-sticky--effects i{
color: #000000FF!important;   
}
.elementor-50 .elementor-element.elementor-element-7d8c0bb.elementor-sticky--effects h1{
color: #000000FF!important;   
}

/* Logo states at init*/
.sticky-img {
 display: none!important;
}
.static-img {
 display: inline!important;
}

/* Swap Logos When Scrolling */
.elementor-sticky--effects .static-img{
 display: none!important;
}
.elementor-sticky--effects .sticky-img{
 display: inline!important;
}



/*MAIN MENU*/
/*dropdown light grey*//*
.elementor-sticky--effects .elementor-nav-menu--dropdown{
    background-color: #ECECECFF!important;
}*/


/*font black*/
.elementor-sticky--effects .main-menu a{
    color: #000 !important;
}

/* keep black when active...*/
.elementor-sticky--effects .main-menu .elementor-item-active{
    color: #FFF !important;
    background-color: #000 !important;
}
/*...and white arrow*/
.elementor-sticky--effects .main-menu .elementor-item-active .sub-arrow i{
    color: #FFF !important;
}

/*white on black when highlighted*/
.elementor-sticky--effects .elementor-nav-menu--dropdown .highlighted {
    color: #FFF !important;
    background-color: #000!important;
}

/*white on black on hover*/
.elementor-sticky--effects .main-menu a:hover {
    color: #FFF !important;
    background-color: #000 !important;
}

/*main stays black when going down in dropdown...*/
.elementor-sticky--effects .main-menu .highlighted {
    color: #FFF !important;
    background-color: #000 !important;
}
/* ...and arrow white*/
.elementor-sticky--effects .main-menu .highlighted .sub-arrow i{
    color: #FFF !important;
}

/*toggle icon white on black on hover*/
.elementor-sticky--effects .elementor-nav-menu--dropdown .highlighted .sub-arrow i{
    color: #FFF!important;
}/* End custom CSS */
